  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "lint": "eslint --ext .js,.mjs src test",
    "lint:fix": "eslint --fix --ext .js,.mjs src test"
  },
  "keywords": [
    "carbonenginejs",
    "reader-hlsl",
    "tr2",
    "trinity",
    "effect",
    "shader",
    "hlsl",
    "eve-online"
  ],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carbonenginejs/reader-hlsl.git"
  },
  "homepage": "https://github.com/carbonenginejs/reader-hlsl#readme",
  "bugs": {
    "url": "https://github.com/carbonenginejs/reader-hlsl/issues"
  },
