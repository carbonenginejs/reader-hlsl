{
  "name": "@carbonenginejs/reader-hlsl",
  "version": "0.1.0",
  "description": "CarbonEngineJS Tr2 effect container reader. Parses CCP's compiled effect files (permutation axes, techniques, passes and shader stage metadata) and emits JSON or raw graph objects for shader translation backends.",
