{
  "name": "@carbonenginejs/format-hlsl",
  "version": "0.1.2",
  "description": "CarbonEngineJS Tr2 effect container format package. Parses CCP's compiled effect files (permutation axes, techniques, passes and shader stage metadata) and emits JSON or raw graph objects for shader translation backends.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "format-hlsl": "./bin/format-hlsl.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "metadata": "node ./bin/format-hlsl.js metadata",
    "lint": "eslint --ext .js,.mjs src test bin",
    "lint:fix": "eslint --fix --ext .js,.mjs src test bin"
  },
  "keywords": [
    "carbonenginejs",
    "format-hlsl",
    "tr2",
    "trinity",
    "effect",
    "shader",
    "hlsl",
    "eve-online"
  ],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carbonenginejs/format-hlsl.git"
  },
  "homepage": "https://github.com/carbonenginejs/format-hlsl#readme",
  "bugs": {
    "url": "https://github.com/carbonenginejs/format-hlsl/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
